# Public host routing
NEXT_PUBLIC_INSPECTION_HUB_HOST=inspectionhub.co
NEXT_PUBLIC_SEE_IT_HOST=seeitinspections.com.au
NEXT_PUBLIC_ACQUISITION_HOST=buildingpestinspectiongoldcoast.com.au

# Supabase (use local values from `supabase start` for development)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
# Optional server-only endpoint override for trusted RPC calls.
SUPABASE_API_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
RATE_LIMIT_HASH_SECRET=replace-with-at-least-32-random-characters

# Safe adapter defaults. Live providers require explicit launch authority.
PROVIDER_MODE=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
GOOGLE_CALENDAR_CREDENTIALS_JSON=
OPENAI_API_KEY=
OPENAI_STORE=false

# Build Week recipient portal. Public/deployed environments use the canonical
# Supabase RPC authority. The filesystem adapter is accepted only when
# APP_ENV=test and is reserved for the isolated E2E harness.
BUILD_WEEK_FIXTURES_ENABLED=false
RECIPIENT_DEMO_ACCESS_ENABLED=false
RECIPIENT_DEMO_OTP=
RECIPIENT_AUTHORITY_ADAPTER=supabase
RECIPIENT_DEMO_STATE_FILE=
RECIPIENT_SESSION_SECRET=

# Worker/runtime
APP_ENV=development
WORKER_ID=local-worker
LOG_LEVEL=info
