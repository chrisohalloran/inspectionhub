{
  "name": "@inspection/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "build": "pnpm typecheck && expo export --platform ios --output-dir dist",
    "clean": "rimraf .expo dist",
    "dev": "expo start --dev-client",
    "lint": "eslint App.tsx src modules/*/index.ts modules/*/src",
    "start": "expo start --dev-client",
    "typecheck": "tsc --noEmit && tsc --noEmit -p modules/expo-durable-file/tsconfig.json"
  },
  "dependencies": {
    "@inspection/contracts": "workspace:*",
    "@inspection/domain": "workspace:*",
    "@inspection/test-fixtures": "workspace:*",
    "@inspection/theme": "workspace:*",
    "expo": "57.0.6",
    "expo-audio": "~57.0.2",
    "expo-battery": "~57.0.1",
    "expo-camera": "~57.0.2",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-network": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.7.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17"
  }
}
