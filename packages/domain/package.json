{
  "name": "@inspection/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./inspection/mobile": {
      "types": "./src/inspection/mobile.ts",
      "react-native": "./src/inspection/mobile.ts",
      "development": "./src/inspection/mobile.ts",
      "import": "./dist/inspection/mobile.js"
    },
    "./inspection/types": {
      "types": "./src/inspection/types.ts",
      "react-native": "./src/inspection/types.ts",
      "development": "./src/inspection/types.ts",
      "import": "./dist/inspection/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@inspection/contracts": "workspace:*"
